# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX). Leave empty to disable analytics.
NEXT_PUBLIC_GA4_ID=

# Canonical site URL for SEO/OG (e.g. https://zedlevel.com). No trailing slash.
NEXT_PUBLIC_SITE_URL=

# Optional: Google Sheet webhook for silent lead capture (disabled by default, see §9 of the build spec)
LEAD_WEBHOOK_URL=
